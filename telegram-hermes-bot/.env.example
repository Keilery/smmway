# === Telegram ===
# Токен бота от @BotFather
TELEGRAM_BOT_TOKEN=

# === LLM (Hermes через OpenRouter) ===
# API-ключ OpenRouter: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Модель Hermes на OpenRouter.
# Дешевле/быстрее: nousresearch/hermes-3-llama-3.1-8b
# Умнее/дороже:   nousresearch/hermes-3-llama-3.1-70b
HERMES_MODEL=nousresearch/hermes-3-llama-3.1-70b

# === Поведение агента ===
# Системный промпт (личность ассистента)
SYSTEM_PROMPT=Ты — Hermes, дружелюбный и полезный ИИ-ассистент в Telegram. Отвечай ясно, по делу и на языке пользователя.

# Сколько последних сообщений диалога хранить в контексте
MAX_HISTORY_MESSAGES=20

# Путь к файлу базы данных SQLite (история диалогов)
DB_PATH=data/bot.db

# Таймаут запроса к модели (в секундах)
REQUEST_TIMEOUT=60
